                <mxCell id="tier-l1" value="L1 — In-Process Cache  (per API instance)" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" parent="1" vertex="1">
