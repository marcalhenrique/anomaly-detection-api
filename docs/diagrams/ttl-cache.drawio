                </mxCell>
                <mxCell id="l2-meta" value="&lt;b&gt;Redis&lt;/b&gt;&#xa;TTL = 3 600 s  (1 h)&#xa;Fixed expiry (no refresh on hit)&#xa;&#xa;Keys:&#xa;  metadata:latest:{series_id}&#xa;  metadata:version:{series_id}:{ver}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;verticalAlign=top;" parent="tier-l2" vertex="1">
                    <mxGeometry x="60" y="40" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="l2-model" value="&lt;b&gt;Redis&lt;/b&gt;&#xa;TTL = 86 400 s  (24 h)&#xa;&lt;i&gt;Sliding expiry — TTL reset on every L2 hit&lt;/i&gt;&#xa;  redis.expire(key, 86 400) on read&#xa;&#xa;Key:  model:{run_id}&#xa;Value: {&quot;mean&quot;: float, &quot;std&quot;: float}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;verticalAlign=top;" parent="tier-l2" vertex="1">
