                <mxCell id="l1-meta" value="&lt;b&gt;TTLCache&lt;/b&gt;&#xa;maxsize = 100 entries&#xa;ttl = 60 s&#xa;&#xa;Keys:&#xa;  latest:{series_id}&#xa;  version:{series_id}:{ver}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;verticalAlign=top;" parent="tier-l1" vertex="1">
